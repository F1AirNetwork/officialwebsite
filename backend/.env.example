# ═══════════════════════════════════════════════════════════════════════════
# F1 Air API Configuration (.env.example)
# ═══════════════════════════════════════════════════════════════════════════
# 
# IMPORTANT: 
# 1. Copy this file to .env 
# 2. Fill in your actual values
# 3. NEVER commit .env to git (add to .gitignore)
# 4. For production, set these in your hosting platform's environment variables
#
# ═══════════════════════════════════════════════════════════════════════════

# ─── Environment ──────────────────────────────
# development: Enables verbose logging, localhost rate limit skip
# production: Enables optimizations, active rate limiting
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────
# Your MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net
MONGODB_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net

# ─── Frontend Origins (CORS) ──────────────────
# Development
CLIENT_ORIGIN=http://localhost:5173
# Production: Set this in your hosting platform
# CLIENT_ORIGIN=https://your-frontend-domain.com

# For multiple origins (comma-separated):
# CLIENT_ORIGINS=https://your-frontend.com,https://admin-panel.com
CLIENT_ORIGINS=

# ─── Authentication ──────────────────────────
# Generate strong random strings (openssl rand -hex 64)
JWT_ACCESS_SECRET=your_strong_secret_key_here_min_64_chars
JWT_REFRESH_SECRET=your_strong_secret_key_here_min_64_chars_different
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google OAuth ─────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
# Production: GOOGLE_CALLBACK_URL=https://your-backend.com/api/auth/google/callback

# ─── Email Configuration ──────────────────────
# Resend (Recommended for production - no SMTP blocking)
# Get from: https://resend.com
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=your_verified_sender@resend.dev

# Gmail (Alternative for local development only - blocked on most cloud platforms)
# Use "App Password" (not your actual password)
# https://myaccount.google.com/apppasswords
# GMAIL_USER=your_email@gmail.com
# GMAIL_APP_PASSWORD=your_app_password_here

# ─── Cloudinary (Image Storage) ───────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Razorpay Payment Gateway ─────────────────
# Get from: https://dashboard.razorpay.com/settings/api-keys
RAZORPAY_KEY_ID=rzp_test_xxxxx  # or rzp_live_xxxxx for production
RAZORPAY_KEY_SECRET=your_secret_key

# ─── Exchange Rates (for USD/EUR conversion) ──
EXCHANGE_RATE_USD=92.43
EXCHANGE_RATE_EUR=105.89

# ─── LemonSqueezy Payment Gateway ────────────
# Get from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your_jwt_token_here
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_STORE_ID_EUR=your_eur_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# ─── Redis Configuration (Rate Limiting) ─────
# For development: Leave as localhost (or omit)
# For production: Use managed Redis service
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. MongoDB Atlas:
#    - Create account: https://www.mongodb.com/cloud/atlas
#    - Create cluster
#    - Copy connection string and update MONGODB_URI
#
# 2. Google OAuth:
#    - Go to: https://console.cloud.google.com
#    - Create new project
#    - Enable Google+ API
#    - Create OAuth 2.0 credentials (Web application)
#    - Add authorized JavaScript origins & redirect URIs
#
# 3. Cloudinary:
#    - Sign up: https://cloudinary.com
#    - Get API credentials from Dashboard
#
# 4. Razorpay:
#    - Sign up: https://razorpay.com
#    - Get API keys from Settings > API Keys
#
# 5. Gmail:
#    - Enable 2-Factor Authentication
#    - Create App Password: https://myaccount.google.com/apppasswords
#
# 6. LemonSqueezy:
#    - Sign up: https://lemonsqueezy.com
#    - Create store
#    - Get API key from Settings
#
# 7. Redis (Optional but recommended):
#    - For development: Install locally or use Docker
#    - For production: Use Redis Cloud or AWS ElastiCache
#
# ═══════════════════════════════════════════════════════════════════════════
